# --- Supabase API Keys (Used by client and server-side Supabase JS SDK) ---
NEXT_PUBLIC_SUPABASE_URL=https://ygjmbeeuomwiciyjkmbd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here

# --- PostgreSQL Database Connection Options ---

# Option A: Connection Pooler (Recommended for IPv4-only networks & Serverless)
# Hostname: aws-1-ap-southeast-2.pooler.supabase.com (port 6543 for Transaction, 5432 for Session)
# User format: postgres.[project-ref]
# Note: Ensure the pooler is enabled in Supabase Dashboard (Settings > Database > Connection Pooling).
# Password special characters (like @, #) MUST be percent-encoded in DATABASE_URL:
#   '@' -> '%40'
#   '#' -> '%23'
DATABASE_URL=postgresql://postgres.ygjmbeeuomwiciyjkmbd:Forg%402030%23%40@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres
DB_HOST=aws-1-ap-southeast-2.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.ygjmbeeuomwiciyjkmbd
DB_PASSWORD=Forg@2030#@
DB_NAME=postgres

